# Production environment template.
# Copy to a private env file or server secret store and replace placeholders outside Git.

NODE_ENV=production

VITE_API_BASE_URL=https://your-domain.example
VITE_PROVIDER_DEFAULT_BASE_URL=https://your-provider.example/v1

SERVER_PORT=5409
STATIC_DIST_DIR=dist
UPLOADS_DIR=uploads
CORS_ALLOWED_ORIGINS=https://your-domain.example

DATABASE_URL=your_database_url

# Production migration is never part of application startup. Keep both values false
# except in the separately authorized migration process after backup verification.
OKWOOK_ALLOW_PRODUCTION_MIGRATION=0
OKWOOK_PRODUCTION_BACKUP_VERIFIED=0

# No real SMS or email adapter exists in the current no-call baseline. Do not enable
# verification-code login in production until a separately authorized adapter task is complete.
AUTH_VERIFICATION_DELIVERY_PROVIDER=
AUTH_VERIFICATION_DELIVERY_READY=false
AUTH_VERIFICATION_DEBUG_AUTOFILL=false

# Frozen no-call baseline: every local/demo or real-call override must remain disabled.
OKPICAI_ALLOW_LOCAL_DEMO_FIXTURES=false
ENABLE_LOCAL_PAYMENT_SIMULATION=false
AI_PROVIDER_REAL_GENERATION_ALLOWED=false
AI_PROVIDER_REAL_SMOKE_ALLOWED=false
AI_PROVIDER_REAL_TEST_ALLOWED=false
OBJECT_STORAGE_REAL_TEST_ALLOWED=false
OBJECT_STORAGE_REAL_UPLOAD_ALLOWED=false
AI_GATEWAY_DEBUG_HEADERS=false


PAYMENT_PROVIDER=mock
PAYMENT_ENVIRONMENT=mock
PAYMENT_MOCK_ENABLED=false
PAYMENT_ALIPAY_ENABLED=false
PAYMENT_WECHAT_ENABLED=false
PAYMENT_AGGREGATOR_ENABLED=false
PAYMENT_SANDBOX_REAL_CALLS_ALLOWED=false

PAYMENT_NOTIFY_URL=https://your-domain.example/api/marketing/payment-webhooks
PAYMENT_RETURN_URL=https://your-domain.example/payment/result
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret

# Use independent strong current keys. These placeholders are deliberately rejected
# by production preflight. Previous keys are optional and decrypt-only during a
# separately authorized rotation window.
PROVIDER_CONFIG_SECRET=your_strong_provider_config_secret
PROVIDER_CONFIG_SECRET_PREVIOUS=
STORAGE_CONFIG_SECRET=your_strong_storage_config_secret
STORAGE_CONFIG_SECRET_PREVIOUS=
PROVIDER_DEFAULT_BASE_URL=https://your-provider.example/v1

AUTH_LOGIN_CODE_EXPIRE_MINUTES=5
AUTH_SESSION_EXPIRE_DAYS=30

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=1
REDIS_URL=your_redis_url

REDIS_PREFIX=canana
REDIS_ENV=production
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_TASK_RUNTIME_TTL_SECONDS=1800
REDIS_TASK_SNAPSHOT_TTL_SECONDS=1800
REDIS_TASK_ABORT_TTL_SECONDS=300
REDIS_TASK_LOCK_TTL_MS=30000
REDIS_TASK_IDEMPOTENCY_TTL_SECONDS=600
REDIS_TASK_CONCURRENCY_TTL_SECONDS=1800
REDIS_RATE_LIMIT_WINDOW_SECONDS=60
REDIS_TASK_SUBMIT_RATE_LIMIT=6
REDIS_TASK_USER_CONCURRENCY_LIMIT=3
REDIS_TASK_PROVIDER_CONCURRENCY_LIMIT=8
REDIS_TASK_SKILL_CONCURRENCY_LIMIT=4
REDIS_AUTH_VERIFICATION_RATE_LIMIT=5
REDIS_AUTH_LOGIN_RATE_LIMIT=10
