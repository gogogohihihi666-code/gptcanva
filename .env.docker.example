# 单端口模式：宿主机暴露端口，同时映射为容器内服务监听端口。
APP_PORT=5409

# 前端访问后端的统一地址。
VITE_API_BASE_URL=https://your-domain.com

# 容器内静态资源目录。
STATIC_DIST_DIR=/app/dist

# 容器内上传目录。
UPLOADS_DIR=/app/uploads

# 允许浏览器访问来源，多个值用逗号分隔。
CORS_ALLOWED_ORIGINS=https://your-domain.com

# MySQL 连接串。
DATABASE_URL=mysql://root:password@host.docker.internal:3306/canana_mind

# The production container must receive NODE_ENV=production from its secret manager.
NODE_ENV=production

# Application startup never runs migrations. Use the separately authorized command only
# after a verified backup, and reset both values to 0 immediately afterwards.
OKWOOK_ALLOW_PRODUCTION_MIGRATION=0
OKWOOK_PRODUCTION_BACKUP_VERIFIED=0

# No real verification-code delivery adapter is implemented in the no-call baseline.
AUTH_VERIFICATION_DELIVERY_PROVIDER=
AUTH_VERIFICATION_DELIVERY_READY=false
AUTH_VERIFICATION_DEBUG_AUTOFILL=false

# Frozen no-call baseline: keep all demo and external-call gates disabled.
OKPICAI_ALLOW_LOCAL_DEMO_FIXTURES=false
ENABLE_LOCAL_PAYMENT_SIMULATION=false
AI_PROVIDER_REAL_GENERATION_ALLOWED=false
AI_PROVIDER_REAL_SMOKE_ALLOWED=false
AI_PROVIDER_REAL_TEST_ALLOWED=false
OBJECT_STORAGE_REAL_TEST_ALLOWED=false
OBJECT_STORAGE_REAL_UPLOAD_ALLOWED=false
AI_GATEWAY_DEBUG_HEADERS=false

# Provider 配置加密密钥。
PROVIDER_CONFIG_SECRET=your_provider_config_secret

# 对象存储配置加密密钥。
STORAGE_CONFIG_SECRET=please-change-this-storage-secret

# 登录验证码有效期（分钟）。
AUTH_LOGIN_CODE_EXPIRE_MINUTES=5

# 登录会话有效期（天）。
AUTH_SESSION_EXPIRE_DAYS=30

# Redis 基础配置（最小必填）
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_URL=

# Redis 高级配置（可选；不填会走默认值）
REDIS_PREFIX=canana
REDIS_ENV=production
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_TASK_RUNTIME_TTL_SECONDS=1800
REDIS_TASK_SNAPSHOT_TTL_SECONDS=1800
REDIS_TASK_ABORT_TTL_SECONDS=300
REDIS_TASK_LOCK_TTL_MS=30000
