# 本文件用于本地 Node 方式启动。
# Docker 部署请参考 .env.docker.example

# 前端 / 服务端统一 API 地址
VITE_API_BASE_URL=http://localhost:5409

# 默认上游厂商地址（用于首次初始化供应商配置）
VITE_PROVIDER_DEFAULT_BASE_URL=https://api.chatfire.site/v1

# 独立后端服务端口
SERVER_PORT=5409

# 生产模式下静态前端构建目录
STATIC_DIST_DIR=dist

# 本地上传文件目录
UPLOADS_DIR=uploads

# 允许跨域访问的前端来源，多个值用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:5010,http://127.0.0.1:5010

# MySQL 连接串
DATABASE_URL="mysql://root:password@127.0.0.1:3306/canana_vue"

# 本地支付确认开关：仅用于开发/测试 no-call 验证，生产环境代码会强制禁用
ENABLE_LOCAL_PAYMENT_SIMULATION=false

# 支付沙箱密钥注入预检：仅 no-call，不会请求真实支付接口
PAYMENT_PROVIDER=mock
PAYMENT_ENVIRONMENT=mock
PAYMENT_MOCK_ENABLED=true
PAYMENT_ALIPAY_ENABLED=false
PAYMENT_WECHAT_ENABLED=false
PAYMENT_AGGREGATOR_ENABLED=false
PAYMENT_SANDBOX_REAL_CALLS_ALLOWED=false

ALIPAY_SANDBOX_APP_ID=your_alipay_sandbox_app_id
ALIPAY_SANDBOX_PRIVATE_KEY=your_alipay_sandbox_private_key
ALIPAY_SANDBOX_PUBLIC_KEY=your_alipay_sandbox_public_key
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

WECHATPAY_SANDBOX_MCH_ID=your_wechatpay_sandbox_mch_id
WECHATPAY_SANDBOX_APP_ID=your_wechatpay_sandbox_app_id
WECHATPAY_SANDBOX_API_V3_KEY=your_wechatpay_sandbox_api_v3_key
WECHATPAY_SANDBOX_PRIVATE_KEY=your_wechatpay_sandbox_private_key
WECHATPAY_SANDBOX_CERTIFICATE=your_wechatpay_sandbox_certificate
WECHATPAY_SANDBOX_SERIAL_NO=your_wechatpay_sandbox_serial_no

PAYMENT_AGGREGATOR_SANDBOX_APP_ID=your_payment_aggregator_sandbox_app_id
PAYMENT_AGGREGATOR_SANDBOX_MERCHANT_ID=your_payment_aggregator_sandbox_merchant_id
PAYMENT_AGGREGATOR_SANDBOX_GATEWAY_URL=https://aggregator-sandbox.example.invalid/gateway
PAYMENT_AGGREGATOR_SANDBOX_PRIVATE_KEY=your_payment_aggregator_sandbox_private_key
PAYMENT_AGGREGATOR_SANDBOX_PUBLIC_KEY=your_payment_aggregator_sandbox_public_key

PAYMENT_NOTIFY_URL=https://your-domain.example/api/marketing/payment-webhooks
PAYMENT_RETURN_URL=https://your-domain.example/payment/result
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret

# Provider 配置加密密钥
PROVIDER_CONFIG_SECRET="please-change-this-secret"

# 对象存储配置加密密钥
STORAGE_CONFIG_SECRET="please-change-this-storage-secret"

# 服务端默认上游厂商地址
PROVIDER_DEFAULT_BASE_URL="https://api.chatfire.site/v1"

# 登录验证码有效期（分钟）
AUTH_LOGIN_CODE_EXPIRE_MINUTES=5

# 登录会话有效期（天）
AUTH_SESSION_EXPIRE_DAYS=30

# Redis 基础配置（最小必填）
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_URL=

# Redis 高级配置（可选；不填会走默认值）
REDIS_PREFIX=canana
REDIS_ENV=development
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_TASK_RUNTIME_TTL_SECONDS=1800
REDIS_TASK_SNAPSHOT_TTL_SECONDS=1800
REDIS_TASK_ABORT_TTL_SECONDS=300
REDIS_TASK_LOCK_TTL_MS=30000
REDIS_TASK_IDEMPOTENCY_TTL_SECONDS=600
REDIS_TASK_CONCURRENCY_TTL_SECONDS=1800
REDIS_RATE_LIMIT_WINDOW_SECONDS=60
REDIS_TASK_SUBMIT_RATE_LIMIT=6
REDIS_TASK_USER_CONCURRENCY_LIMIT=3
REDIS_TASK_PROVIDER_CONCURRENCY_LIMIT=8
REDIS_TASK_SKILL_CONCURRENCY_LIMIT=4
REDIS_AUTH_VERIFICATION_RATE_LIMIT=5
REDIS_AUTH_LOGIN_RATE_LIMIT=10
